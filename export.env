# Authentication Secrets - GENERATE NEW VALUES
NEXTAUTH_URL=https://your-app-name.vercel.app
NEXTAUTH_SECRET=generate_random_32_character_string_here
JWT_SECRET=generate_another_random_32_character_string

# Production Environment
NODE_ENV=production

# ===== INSTRUCTIONS =====
# 1. Ganti "your-app-name" dengan nama actual Vercel app kamu
# 2. Generate random strings untuk NEXTAUTH_SECRET dan JWT_SECRET:
#    - Bisa pakai: openssl rand -base64 32
#    - Atau online generator: https://generate-secret.vercel.app/32
# 3. Set semua variables ini di Vercel Dashboard:
#    - Go to: https://vercel.com/dashboard
#    - Select your project
#    - Settings > Environment Variables
#    - Add each variable above
# 4. Redeploy project setelah set environment variables
